# 数据库配置
DATABASE_URL="postgresql://ai_resume:your_password@localhost:5432/ai_resume?schema=public"

# JWT 配置
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# OpenAI 配置
OPENAI_API_KEY="sk-your-openai-api-key"
OPENAI_MODEL="gpt-4o-mini"

# Redis 配置
REDIS_HOST="localhost"
REDIS_PORT="6379"

# 应用配置
PORT=3001
NODE_ENV=development