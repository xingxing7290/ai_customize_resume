{
  "name": "ai-customize-resume",
  "version": "1.0.0",
  "private": true,
  "description": "AI 驱动的岗位定制简历生成平台",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:generate": "pnpm --filter @ai-resume/database prisma generate",
    "db:migrate": "pnpm --filter @ai-resume/database prisma migrate dev",
    "db:push": "pnpm --filter @ai-resume/database prisma db push",
    "db:studio": "pnpm --filter @ai-resume/database prisma studio",
    "db:seed": "pnpm --filter @ai-resume/database prisma db seed"
  },
  "devDependencies": {
    "prettier": "^3.2.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "packageManager": "pnpm@8.15.0",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "prisma": "^5.10.0"
  }
}
